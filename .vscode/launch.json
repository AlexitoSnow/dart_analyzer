{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Dart Analyzer Backend: Parse algorithm file name",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/backend/src/main.py",
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}",
            "python": "${workspaceFolder}/backend/venv/Scripts/python.exe"
        },
        {
            "name": "Dart Analyzer UI: Launch Frontend",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/frontend/src/app.py",
            "cwd": "${workspaceFolder}/frontend",
            "console": "integratedTerminal",
            "python": "${workspaceFolder}/frontend/venv/Scripts/python.exe"
        }
    ]
}