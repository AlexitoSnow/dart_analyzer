{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Initialize venv",
            "type": "shell",
            "command": "python3 -m venv venv",
            "windows": {
                "command": "python -m venv venv"
            },
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "problemMatcher": []
        },
        {
            "label": "Install Dependencies",
            "type": "shell",
            "command": "venv/bin/python -m pip install -r requirements.txt",
            "windows": {
                "command": ".\\venv\\Scripts\\python.exe -m pip install -r requirements.txt"
            },
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "problemMatcher": [],
            "dependsOn": "Initialize venv"
        }
    ]
}